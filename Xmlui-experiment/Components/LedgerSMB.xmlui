      <CreateClient/>
    </Page>

    <Page url="/icons">
      <Icons/>
    </Page>

    <Page url="/palettes">
      <Palettes/>
    </Page>-->

  </Pages>

  <Theme>
    <Footer>Built with XMLUI
      <ToneChangerButton/>
    </Footer>
  </Theme>

</App>
</Component>